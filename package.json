{
  "name": "kruxt-beta",
  "private": true,
  "version": "0.1.0",
  "description": "KRUXT monorepo (mobile, admin, db, shared types)",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "turbo run build",
    "build:dev": "node -e \"console.log('build:dev check: monorepo scaffold ready')\"",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:test": "bash packages/db/tests/run_smoke.sh"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.24",
    "lovable-tagger": "^1.1.13",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  }
}
