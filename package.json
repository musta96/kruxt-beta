{
  "name": "kruxt-beta",
  "private": true,
  "version": "0.1.0",
  "description": "KRUXT monorepo (mobile, admin, db, shared types)",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "turbo run build",
    "build:dev": "node -e \"console.log('build:dev check: monorepo scaffold ready')\"",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:test": "bash packages/db/tests/run_smoke.sh"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  }
}
